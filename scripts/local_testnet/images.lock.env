# shellcheck shell=bash disable=SC2034 # Variables are consumed by sourcing scripts.
# Immutable external inputs for the VM64 local-testnet gate. Keep the readable
# tags so deliberate updates remain easy to review, but never remove the
# digest. Resolve replacements from the registry and validate them with the
# full local-testnet workflow before merging an update.
# The published consensus images supply immutable Debian 11 runtime
# filesystems only. Their pre-VM64 binaries are always overwritten from the
# exact Qrysm source revision below before Kurtosis sees either image.
PINNED_QRL_PACKAGE_REPO='github.com/rgeraldes24/qrl-package'
PINNED_QRL_PACKAGE_COMMIT='1f31cd03dbe2061225701ea79d956cfeceaf91db'
PINNED_CL_BASE_IMAGE='qrledger/qrysm:beacon-chain-latest@sha256:52b6fbecfe442d0d451e1219652e464d69de8a09edd44d5c54bbbf5ebdb83000'
PINNED_VC_BASE_IMAGE='qrledger/qrysm:validator-latest@sha256:e830b41130a43211803fe3d17eeb0a66cd743f062d5407667ee3531bc5891ede'
# The published generator digest supplies the Python runtime and base
# filesystem only. Its legacy generator sources and Qrysm binaries are
# replaced from the exact source commits below.
PINNED_GENESIS_BASE_IMAGE='qrledger/qrysm:qrl-genesis-generator-latest@sha256:43d975e6b5e22e4de79d9027325cc05f996c2325705f2e199e012788e5faa0eb'
# Match the Bookworm runtime in the immutable generator base so CGO-linked
# Qrysm binaries never depend on a newer glibc.
PINNED_GENESIS_GO_BUILDER_IMAGE='golang:1.25-bookworm@sha256:ea341baa9bd5ba6784f6d7161ace70544349a6242d54d34a0fbfd2c4d51c9d58'
PINNED_QRYSM_GO_BUILDER_IMAGE='golang:1.25-bookworm@sha256:ea341baa9bd5ba6784f6d7161ace70544349a6242d54d34a0fbfd2c4d51c9d58'
PINNED_QRYSM_GIT_REPO='https://github.com/rgeraldes24/qrysm.git'
PINNED_QRYSM_GIT_COMMIT='8b80fa0c3f5a98f2edc3fc8b7b9c67808373cafb'
PINNED_GENERATOR_GIT_REPO='https://github.com/rgeraldes24/qrl-genesis-generator.git'
PINNED_GENERATOR_GIT_COMMIT='3884e4228ef347bbfa4a80a90e819cd05140f122'
PINNED_GO_BUILDER_IMAGE='golang:1.25-alpine@sha256:56961d79ea8129efddcc0b8643fd8a5416b4e6228cfd477e3fd61deb2672c587'
PINNED_ALPINE_RUNTIME_IMAGE='alpine:latest@sha256:28bd5fe8b56d1bd048e5babf5b10710ebe0bae67db86916198a6eec434943f8b'
